# Email Configuration (SMTP relay, e.g. smtp2go, Gmail, custom SMTP)
EMAIL_HOST=mail.smtp2go.com
EMAIL_PORT=587
EMAIL_USER=your-smtp-username
EMAIL_PASS=your-smtp-password
EMAIL_FROM="Secret Santa <noreply@yourdomain.com>"

# Session encryption secret (REQUIRED, min 32 chars)
# Used to encrypt the iron-session cookie. Generate with: openssl rand -base64 32
SESSION_SECRET=your-session-encryption-key-min-32-chars

# Base URL for this deployment (REQUIRED)
# Used to build durable per-person links (${NEXTAUTH_URL}/p/<token>) in emails.
NEXTAUTH_URL=https://your-domain

# Cookie secure flag (OPTIONAL)
# Safe default: secure in production, insecure in development, unless set explicitly.
# Set to "false" only for tailnet/HTTP-only deployments.
# COOKIE_SECURE=true
