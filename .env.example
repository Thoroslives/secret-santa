# Email Configuration (SMTP relay, e.g. smtp2go, Gmail, custom SMTP)
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_USER=your-smtp-username
EMAIL_PASS=your-smtp-password
EMAIL_FROM="Secret Santa <noreply@yourdomain.com>"

# Session encryption secret (REQUIRED, min 32 chars)
# Used to encrypt the iron-session cookie. Generate with: openssl rand -base64 32
SESSION_SECRET=your-session-encryption-key-min-32-chars

# Base URL for this deployment (REQUIRED)
# Used to build durable per-person links (${NEXTAUTH_URL}/p/<token>) in emails.
NEXTAUTH_URL=https://your-domain

# Cookie secure flag (OPTIONAL)
# Safe default: secure in production, insecure in development, unless set explicitly.
# Set to "false" only for tailnet/HTTP-only deployments.
# COOKIE_SECURE=true

# --- Admin authentication (P4) ---
# Break-glass local admin password (set this or you cannot sign in as admin without OIDC).
ADMIN_BREAKGLASS_PASSWORD=change-me-to-a-strong-password
# Comma-separated list of OIDC emails allowed to administer the app (verified emails only).
ADMIN_OIDC_ALLOWED_EMAILS=admin@example.com
# OIDC provider (Authentik). Leave the OIDC_* vars unset to run break-glass-only.
OIDC_ISSUER=https://auth.example.com/application/o/santa/
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret
# Must exactly match the redirect URI registered at the provider.
OIDC_REDIRECT_URI=https://santa.example.com/api/admin/oidc/callback
