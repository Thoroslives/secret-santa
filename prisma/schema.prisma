// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A group represents a Secret Santa event (e.g., "Smith Family 2024")
model Group {
  id             String   @id @default(cuid())
  name           String   // "Smith Family Secret Santa 2024"
  inviteCode     String   @unique  // Unique code for people to join this group
  year           Int      @default(2024)
  plan           String   @default("free") // free, plus, pro
  budgetAmount   Float?   // Optional budget amount
  budgetCurrency String   @default("USD") // Currency code
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  suggestionCap      Int @default(3)
  previousYearMemory Int @default(1)
  organiserName      String?  // organiser's name, shown as the email sign-off
  personalMessage    String?  // optional organiser note included in participant emails

  // Relations
  people       Person[]
  assignments  Assignment[]
  rounds       Round[]
  blocks       Block[]
}

model Person {
  id                String   @id @default(cuid())
  groupId           String   // Links this person to their group
  name              String
  email             String?  // Optional email for self-service link resend
  personalLinkToken String   @unique // Durable, unguessable per-person login link token
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())

  group          Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  wishlistItems  WishlistItem[]
  visits         Visit[]
  giverFor       Assignment[]     @relation("Giver")
  receiverFor    Assignment[]     @relation("Receiver")
  blocksA        Block[]          @relation("BlockA")
  blocksB        Block[]          @relation("BlockB")
  pinsGiven      ForcedPin[]      @relation("PinGiver")
  pinsReceived   ForcedPin[]      @relation("PinReceiver")
  suggestionsFor Suggestion[]     @relation("SuggestionFor")
  suggestionsBy  Suggestion[]     @relation("SuggestionBy")

  @@unique([groupId, email])      // Email must be unique within a group (if provided)
  @@index([groupId])
  @@index([email])
}

model WishlistItem {
  id        String   @id @default(cuid())
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  title     String
  note      String?
  order     Int
  createdAt DateTime @default(now())

  @@index([personId])
}

model Assignment {
  id         String   @id @default(cuid())
  groupId    String   // Assignments are isolated per group
  giverId    String
  receiverId String
  year       Int      // denormalized filter, always == round.year (set together in generate)
  roundId    String
  createdAt  DateTime @default(now())

  group    Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  giver    Person @relation("Giver", fields: [giverId], references: [id], onDelete: Cascade)
  receiver Person @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  round    Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([giverId, year])
  @@index([groupId])
  @@index([giverId])
  @@index([receiverId])
  @@index([roundId])
}

model Round {
  id String @id @default(cuid())
  groupId String
  year Int
  status String @default("draft")   // draft | generated | sent
  sentAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  assignments Assignment[]
  forcedPins ForcedPin[]
  suggestions Suggestion[]
  @@unique([groupId, year])
  @@index([groupId])
}
model Block {
  id String @id @default(cuid())
  groupId String
  personAId String
  personBId String
  createdAt DateTime @default(now())
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  personA Person @relation("BlockA", fields: [personAId], references: [id], onDelete: Cascade)
  personB Person @relation("BlockB", fields: [personBId], references: [id], onDelete: Cascade)
  @@index([groupId])
}
model ForcedPin {
  id String @id @default(cuid())
  roundId String
  giverId String
  receiverId String
  createdAt DateTime @default(now())
  round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)
  giver Person @relation("PinGiver", fields: [giverId], references: [id], onDelete: Cascade)
  receiver Person @relation("PinReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  @@unique([roundId, giverId])
  @@index([roundId])
}
model Suggestion {
  id          String   @id @default(cuid())
  roundId     String
  forPersonId String   // the person the suggestion is ABOUT (never sees it)
  byPersonId  String   // the suggester (sees only their own)
  name        String
  note        String?
  named       Boolean  @default(false) // suggester's per-suggestion named/anon choice
  createdAt   DateTime @default(now())
  round     Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  forPerson Person @relation("SuggestionFor", fields: [forPersonId], references: [id], onDelete: Cascade)
  byPerson  Person @relation("SuggestionBy",  fields: [byPersonId],  references: [id], onDelete: Cascade)
  @@index([roundId])
  @@index([forPersonId])
  @@index([byPersonId, forPersonId, roundId]) // the cap-count query
}

// A participant opening the app. The FIRST thing this app records purely to be measured:
// every other count on the dashboard (wishlist items, suggestions) is a free COUNT over
// rows that exist because someone wanted them. A visit leaves no such row behind.
//
// `bucket` is floor(epochMs / VISIT_DEBOUNCE_MS) and carries the debounce: see the unique
// key below and the long comment in lib/visits.ts.
//
// `year` is a SNAPSHOT of Group.year (via getActiveYear) taken at visit time. Note this is a
// weaker guarantee than Assignment.year, which is written together with its roundId inside
// the generate transaction: a Visit has no FK to Round, and visits routinely exist for a year
// before any Round row for that year does (rollover bumps Group.year immediately, while Round
// is only materialised lazily by ensureRound). It is stored because rollover wipes wishlists
// and suggestions, so a lifetime total would quietly fold last Christmas into this one's
// picture. Read it back the same way it was written - filtered on the active year - and do
// not assume it is backed by a Round.
model Visit {
  id        String   @id @default(cuid())
  personId  String
  year      Int
  bucket    Int      // floor(epochMs / VISIT_DEBOUNCE_MS). The debounce IS this key.
  createdAt DateTime @default(now())
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  // One visit per person per half hour, enforced by the database rather than by a
  // read-then-write. This index also serves the dashboard's read (WHERE personId IN (...)),
  // which is why there is no separate index on createdAt: EXPLAIN QUERY PLAN confirms SQLite
  // picks this one, so another index would be write cost on the participant hot path for a
  // read that never uses it.
  //
  // `year` is IN the key, and it has to be. Without it, a participant who opens their wishlist
  // in the same half-hour bucket in which they had already visited under the LAST year would
  // collide, and recordVisit would swallow it as an ordinary debounce hit - losing their first
  // visit of the new season and reporting them as "Never opened their link" until they came
  // back in a later bucket. Narrow (a 30-minute window straight after a rollover) but free to
  // close, and it costs the debounce nothing: within one year the key is still one row per
  // person per bucket.
  @@unique([personId, year, bucket])
}
